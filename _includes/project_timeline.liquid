<section id="posts" class="project-timeline-section">
  <div class="project-timeline">
    {% assign sorted_projects = site.projects | sort: 'date' | reverse %}
    {% for project in sorted_projects %}
      <div class="project-timeline-item" data-date="{{ project.date | date_to_xmlschema }}">
        <div class="project-timeline-marker"></div>
        <div class="project-timeline-content">
          <time datetime="{{ project.date | date_to_xmlschema }}">{{ project.date | date: '%B %d, %Y' }}</time>
          <h3>
            <a href="{{ project.url | relative_url }}">{{ project.title }}</a>
          </h3>
          <p>{{ project.description }}</p>
          {% if project.img %}
            <div class="project-timeline-thumb">
              {% include figure.liquid loading="lazy" path=project.img sizes="320px" alt=project.title class="img-fluid rounded" %}
            </div>
          {% endif %}
          {% if project.tags %}
            <div class="project-timeline-tags">
              {% for tag in project.tags %}
                <span class="badge badge-light">{{ tag }}</span>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<script>
  (function () {
    'use strict';

    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -100px 0px',
    };

    const observer = new IntersectionObserver(function (entries) {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('project-timeline-item-visible');
        }
      });
    }, observerOptions);

    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('.project-timeline-item').forEach((item) => {
        observer.observe(item);
      });
    });
  })();
</script>
