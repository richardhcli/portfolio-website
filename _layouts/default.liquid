<!doctype html>
<html lang="{{ site.lang }}">
  <!-- Head -->
  <head>
    {% if page.redirect %}
      {% if page.redirect == true %}
        {% assign redirect = site.baseurl | append: '/' %}
      {% elsif page.redirect contains '://' %}
        {% assign redirect = page.redirect %}
      {% else %}
        {% assign redirect = page.redirect | relative_url %}
      {% endif %}
      <meta http-equiv="refresh" content="3; url={{ redirect }}">
    {% endif %}
    {% include head.liquid %}
  </head>

  <!-- Body -->
  <body class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}{% if site.profile_sidebar.enabled %} has-profile-sidebar{% endif %}">
    <!-- Header -->
    {% include header.liquid %}

    {% if site.profile_sidebar.enabled %}
      <div class="site-layout">
        {% include profile_sidebar.liquid %}

        <main class="site-main" role="main">
          <div class="container mt-5 site-main__content">
            {% if page.toc and page.toc.sidebar %}
              {% if page.toc.sidebar == 'right' %}
                <div class="row page-with-year-toc">
                  <div class="col-12 col-lg page-content-col order-lg-1">{{ content }}</div>
                  <div class="col-12 col-lg-auto toc-sidebar-col order-lg-2">
                    <nav id="toc-sidebar" class="sticky-top"></nav>
                  </div>
                </div>
              {% else %}
                <div class="row page-with-year-toc">
                  <div class="col-12 col-lg-auto toc-sidebar-col">
                    <nav id="toc-sidebar" class="sticky-top"></nav>
                  </div>
                  <div class="col-12 col-lg page-content-col">{{ content }}</div>
                </div>
              {% endif %}
            {% else %}
              {{ content }}
            {% endif %}
          </div>
        </main>
      </div>
    {% else %}
      <!-- Content -->
      <div class="container mt-5" role="main">
        {% if page.toc and page.toc.sidebar %}
          {% if page.toc.sidebar == 'right' %}
            <div class="row page-with-year-toc">
              <div class="col-12 col-lg page-content-col order-lg-1">{{ content }}</div>
              <div class="col-12 col-lg-auto toc-sidebar-col order-lg-2">
                <nav id="toc-sidebar" class="sticky-top"></nav>
              </div>
            </div>
          {% else %}
            <div class="row page-with-year-toc">
              <div class="col-12 col-lg-auto toc-sidebar-col">
                <nav id="toc-sidebar" class="sticky-top"></nav>
              </div>
              <div class="col-12 col-lg page-content-col">{{ content }}</div>
            </div>
          {% endif %}
        {% else %}
          {{ content }}
        {% endif %}
      </div>
    {% endif %}

    <!-- Footer -->
    {% include footer.liquid %}

    <!-- JavaScripts -->
    {% include scripts.liquid %}
  </body>
</html>
